+
+
+class ExpertDistributionRecorder:
+    """Record per-forward MoE routing metadata in an SGLang-like format."""
+
+    def __init__(self, vllm_config: VllmConfig, output_path: str):
+        from vllm.distributed.parallel_state import get_ep_group
+        from vllm.model_executor.layers.fused_moe.layer import FusedMoE
+
+        self.vllm_config = vllm_config
+        self.parallel_config = vllm_config.parallel_config
+        self.mode = vllm_config.observability_config.expert_distribution_recorder_mode
+        assert self.mode is not None
+
+        if torch.distributed.is_initialized():
+            self.global_rank = torch.distributed.get_rank()
+        else:
+            self.global_rank = 0
+        self.data_parallel_rank = self.parallel_config.data_parallel_rank
+        self.pipeline_parallel_rank = get_pp_group().rank_in_group
+        self.tensor_parallel_rank = get_tensor_model_parallel_rank()
+        self.expert_parallel_rank = (
+            get_ep_group().rank_in_group
+            if self.parallel_config.enable_expert_parallel
+            else 0
+        )
+
+        self._forward_pass_id = 0
+        self._recording = True
+        self._dumped = False
+
+        modules = {
+            module.layer_id: module
+            for module in vllm_config.compilation_config.static_forward_context.values()
+            if isinstance(module, FusedMoE)
+        }
+        if not modules:
+            raise ValueError(
+                "expert_distribution_recorder_mode requires at least one FusedMoE "
+                "layer in the loaded model."
+            )
+        self.modules = modules
+
+        hf_config = vllm_config.model_config.hf_text_config
+        self.num_layers = hf_config.num_hidden_layers
+        self.num_experts_per_tok = hf_config.num_experts_per_tok
+        self.num_logical_experts = max(module.logical_num_experts for module in modules.values())
+        self.num_physical_experts = max(module.global_num_experts for module in modules.values())
+        self.num_local_physical_experts = max(
+            module.local_num_experts for module in modules.values()
+        )
+        self.ep_size = max(
+            module.ep_size if module.use_ep else 1 for module in modules.values()
+        )
+
+        (
+            self.physical_to_logical_map_cpu,
+            self.logical_to_all_physical_map_cpu,
+            self.logical_to_all_physical_map_num_valid_cpu,
+            self.physical_expert_owner_ep_rank_cpu,
+        ) = self._build_layer_mappings(modules)
+
+        self._global_physical_count_steps: list[torch.Tensor] = []
+        self._logical_count_steps: list[torch.Tensor] = []
+        self._forward_pass_ids: list[int] = []
+        self._forward_modes: list[int] = []
+        self._global_forward_modes: list[int | None] = []
+        self._is_extend_in_batch: list[bool] = []
+        self._forward_request_ids: list[list[str] | None] = []
+        self._forward_request_spans: list[list[dict[str, Any]]] = []
+        self._records: list[dict[str, Any]] = []
+        self._physical_to_logical_map_steps: list[torch.Tensor] = []
+        self._logical_to_all_physical_map_steps: list[torch.Tensor] = []
+        self._logical_to_all_physical_map_num_valid_steps: list[torch.Tensor] = []
+        self._physical_expert_owner_ep_rank_steps: list[torch.Tensor] = []
+
+        self.output_path = self._resolve_output_path(output_path)
+        atexit.register(self.dump)
+
+    @staticmethod
+    def create(vllm_config: VllmConfig) -> "ExpertDistributionRecorder | None":
+        mode = vllm_config.observability_config.expert_distribution_recorder_mode
+        output_path = (
+            vllm_config.observability_config.expert_distribution_recorder_output
+        )
+        if mode is None or output_path is None:
+            return None
+
+        tp_rank = get_tensor_model_parallel_rank()
+        ep_rank = 0
+        if vllm_config.parallel_config.enable_expert_parallel:
+            from vllm.distributed.parallel_state import get_ep_group
+
+            ep_rank = get_ep_group().rank_in_group
+
+        # One recorder per TP/EP shard is enough because the logical routing
+        # decisions are replicated across those ranks.
+        if tp_rank != 0 or ep_rank != 0:
+            return None
+
+        return ExpertDistributionRecorder(vllm_config, output_path)
+
+    def start(self) -> None:
+        self._recording = True
+
+    def stop(self) -> None:
+        self._recording = False
+
+    @property
+    def recording(self) -> bool:
+        return self._recording
+
+    def record_step(
+        self,
+        captured_topk_ids: torch.Tensor,
+        captured_physical_topk_ids: torch.Tensor,
+        input_ids: torch.Tensor,
+        positions: torch.Tensor,
+        req_ids: list[str],
+        num_scheduled_tokens: list[int],
+        num_computed_tokens_before: list[int],
+        num_prompt_tokens: list[int],
+    ) -> None:
+        if not self._recording:
+            return
+
+        forward_pass_id = self._forward_pass_id
+        self._forward_pass_id += 1
+
+        spans, token_request_ids, token_forward_modes = self._build_request_spans(
+            req_ids=req_ids,
+            num_scheduled_tokens=num_scheduled_tokens,
+            num_computed_tokens_before=num_computed_tokens_before,
+            num_prompt_tokens=num_prompt_tokens,
+        )
+        forward_mode = self._infer_forward_mode(token_forward_modes)
+        global_forward_mode = forward_mode
+        is_extend_in_batch = forward_mode in (1, 3)
+        (
+            physical_to_logical_map_cpu,
+            logical_to_all_physical_map_cpu,
+            logical_to_all_physical_map_num_valid_cpu,
+            physical_expert_owner_ep_rank_cpu,
+        ) = self._build_layer_mappings(self.modules)
+
+        global_physical_count = self._compute_global_physical_count(
+            captured_physical_topk_ids
+        ).cpu()
+        logical_count = self._compute_logical_count_from_global_physical_count(
+            global_physical_count,
+            physical_to_logical_map=physical_to_logical_map_cpu,
+        ).cpu()
+
+        self._global_physical_count_steps.append(global_physical_count)
+        self._logical_count_steps.append(logical_count)
+        self._forward_pass_ids.append(forward_pass_id)
+        self._forward_modes.append(forward_mode)
+        self._global_forward_modes.append(global_forward_mode)
+        self._is_extend_in_batch.append(is_extend_in_batch)
+        self._forward_request_ids.append(list(req_ids) if req_ids else None)
+        self._forward_request_spans.append(spans)
+        self._physical_to_logical_map_steps.append(physical_to_logical_map_cpu.clone())
+        self._logical_to_all_physical_map_steps.append(
+            logical_to_all_physical_map_cpu.clone()
+        )
+        self._logical_to_all_physical_map_num_valid_steps.append(
+            logical_to_all_physical_map_num_valid_cpu.clone()
+        )
+        self._physical_expert_owner_ep_rank_steps.append(
+            physical_expert_owner_ep_rank_cpu.clone()
+        )
+        self.physical_to_logical_map_cpu = physical_to_logical_map_cpu
+        self.logical_to_all_physical_map_cpu = logical_to_all_physical_map_cpu
+        self.logical_to_all_physical_map_num_valid_cpu = (
+            logical_to_all_physical_map_num_valid_cpu
+        )
+        self.physical_expert_owner_ep_rank_cpu = physical_expert_owner_ep_rank_cpu
+
+        if self.mode == "per_token":
+            self._records.append(
+                dict(
+                    forward_pass_id=forward_pass_id,
+                    rank=self.global_rank,
+                    gatherer_key="select_experts",
+                    input_ids=input_ids.cpu().tolist(),
+                    positions=positions.cpu().tolist(),
+                    request_ids=list(req_ids),
+                    token_request_ids=token_request_ids,
+                    token_forward_modes=token_forward_modes,
+                    request_spans=spans,
+                    forward_mode=forward_mode,
+                    global_forward_mode=global_forward_mode,
+                    is_extend_in_batch=is_extend_in_batch,
+                    topk_ids_of_layer=captured_physical_topk_ids.permute(1, 0, 2).cpu(),
+                    logical_topk_ids_of_layer=captured_topk_ids.permute(1, 0, 2).cpu(),
+                    global_physical_count=global_physical_count.clone(),
+                    logical_count=logical_count.clone(),
+                    physical_to_logical_map=physical_to_logical_map_cpu.clone(),
+                    logical_to_all_physical_map=logical_to_all_physical_map_cpu.clone(),
+                    logical_to_all_physical_map_num_valid=(
+                        logical_to_all_physical_map_num_valid_cpu.clone()
+                    ),
+                    physical_expert_owner_ep_rank=(
+                        physical_expert_owner_ep_rank_cpu.clone()
+                    ),
+                )
+            )
+
+    def dump(self) -> Path | None:
+        if self._dumped:
+            return self.output_path
+        if self.mode is None:
+            return None
+
+        self._dumped = True
+        self.output_path.parent.mkdir(parents=True, exist_ok=True)
+
+        if self.mode == "per_token":
+            payload = dict(
+                records=self._records,
+                last_physical_to_logical_map=self.physical_to_logical_map_cpu.clone(),
+                logical_to_all_physical_map=self.logical_to_all_physical_map_cpu.clone(),
+                logical_to_all_physical_map_num_valid=self.logical_to_all_physical_map_num_valid_cpu.clone(),
+                physical_expert_owner_ep_rank=self.physical_expert_owner_ep_rank_cpu.clone(),
+                num_layers=self.num_layers,
+                num_logical_experts=self.num_logical_experts,
+                num_physical_experts=self.num_physical_experts,
+                num_local_physical_experts=self.num_local_physical_experts,
+                ep_size=self.ep_size,
+                data_parallel_rank=self.data_parallel_rank,
+                pipeline_parallel_rank=self.pipeline_parallel_rank,
+                tensor_parallel_rank=self.tensor_parallel_rank,
+                expert_parallel_rank=self.expert_parallel_rank,
+            )
+        else:
+            payload = self._build_stat_payload()
+
+        torch.save(payload, self.output_path)
+        logger.info("Saved expert distribution record to %s", self.output_path)
+        return self.output_path
+
+    def _build_layer_mappings(
+        self, modules: dict[int, Any]
+    ) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor, torch.Tensor]:
+        default_map = (
+            torch.arange(self.num_physical_experts, dtype=torch.int64)
+            % max(self.num_logical_experts, 1)
+        )
+        physical_to_logical_map = default_map.repeat(self.num_layers, 1)
+        logical_to_all_physical_map = torch.full(
+            (self.num_layers, self.num_logical_experts, self.num_physical_experts),
+            -1,
+            dtype=torch.int64,
+        )
+        logical_to_all_physical_map_num_valid = torch.zeros(
+            (self.num_layers, self.num_logical_experts), dtype=torch.int64
+        )
+        default_owner = (
+            torch.arange(self.num_physical_experts, dtype=torch.int64)
+            // max(self.num_local_physical_experts, 1)
+        ).clamp(max=max(self.ep_size - 1, 0))
+        physical_expert_owner_ep_rank = default_owner.repeat(self.num_layers, 1)
+
+        for layer_id, module in modules.items():
+            num_physical = min(module.global_num_experts, self.num_physical_experts)
+            if module.use_ep and module.local_num_experts > 0:
+                physical_expert_owner_ep_rank[layer_id, :num_physical] = (
+                    torch.arange(num_physical, dtype=torch.int64)
+                    // module.local_num_experts
+                ).clamp(max=max(module.ep_size - 1, 0))
+            else:
+                physical_expert_owner_ep_rank[layer_id, :num_physical] = 0
+
+            if (
+                module.enable_eplb
+                and module.eplb_state.logical_to_physical_map is not None
+                and module.eplb_state.logical_replica_count is not None
+            ):
+                layer_map = torch.full(
+                    (self.num_physical_experts,), -1, dtype=torch.int64
+                )
+                logical_to_physical = module.eplb_state.logical_to_physical_map.cpu()
+                logical_replica_count = module.eplb_state.logical_replica_count.cpu()
+                for logical_expert_id in range(logical_to_physical.shape[0]):
+                    replica_count = int(logical_replica_count[logical_expert_id].item())
+                    logical_to_all_physical_map_num_valid[
+                        layer_id, logical_expert_id
+                    ] = replica_count
+                    if replica_count == 0:
+                        continue
+                    physical_ids = logical_to_physical[logical_expert_id, :replica_count]
+                    logical_to_all_physical_map[
+                        layer_id, logical_expert_id, :replica_count
+                    ] = physical_ids.to(torch.int64)
+                    layer_map[physical_ids.to(torch.int64)] = logical_expert_id
+                layer_map[layer_map < 0] = default_map[layer_map < 0]
+                physical_to_logical_map[layer_id] = layer_map
+            else:
+                num_logical = min(module.logical_num_experts, self.num_logical_experts)
+                physical_to_logical_map[layer_id, :num_physical] = (
+                    torch.arange(num_physical, dtype=torch.int64) % max(num_logical, 1)
+                )
+                logical_to_all_physical_map[layer_id, :num_logical, 0] = torch.arange(
+                    num_logical, dtype=torch.int64
+                )
+                logical_to_all_physical_map_num_valid[layer_id, :num_logical] = 1
+
+        return (
+            physical_to_logical_map,
+            logical_to_all_physical_map,
+            logical_to_all_physical_map_num_valid,
+            physical_expert_owner_ep_rank,
+        )
+
+    def _resolve_output_path(self, output_path: str) -> Path:
+        raw_path = Path(output_path).expanduser()
+        if raw_path.suffix == ".pt":
+            if self.global_rank == 0:
+                return raw_path
+            return raw_path.with_name(
+                f"{raw_path.stem}.rank{self.global_rank}{raw_path.suffix}"
+            )
+        return raw_path / f"expert_distribution_recorder.rank{self.global_rank}.pt"
+
+    def _compute_logical_count(self, captured_topk_ids: torch.Tensor) -> torch.Tensor:
+        # captured_topk_ids: [num_tokens, num_layers, topk]
+        layer_major = captured_topk_ids.permute(1, 0, 2).reshape(self.num_layers, -1)
+        mask = (layer_major >= 0) & (layer_major < self.num_logical_experts)
+        indices = layer_major.masked_fill(~mask, 0).to(torch.int64)
+        logical_count = torch.zeros(
+            (self.num_layers, self.num_logical_experts),
+            dtype=torch.int32,
+            device=captured_topk_ids.device,
+        )
+        logical_count.scatter_add_(1, indices, mask.to(torch.int32))
+        return logical_count
+
+    def _compute_global_physical_count(
+        self, captured_physical_topk_ids: torch.Tensor
+    ) -> torch.Tensor:
+        layer_major = captured_physical_topk_ids.permute(1, 0, 2).reshape(
+            self.num_layers, -1
+        )
+        mask = (layer_major >= 0) & (layer_major < self.num_physical_experts)
+        indices = layer_major.masked_fill(~mask, 0).to(torch.int64)
+        global_physical_count = torch.zeros(
+            (self.num_layers, self.num_physical_experts),
+            dtype=torch.int32,
+            device=captured_physical_topk_ids.device,
+        )
+        global_physical_count.scatter_add_(1, indices, mask.to(torch.int32))
+        return global_physical_count
+
+    def _compute_logical_count_from_global_physical_count(
+        self,
+        global_physical_count: torch.Tensor,
+        physical_to_logical_map: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        if physical_to_logical_map is None:
+            physical_to_logical_map = self.physical_to_logical_map_cpu
+        physical_to_logical = physical_to_logical_map.to(device=global_physical_count.device)
+        valid_mask = (physical_to_logical >= 0) & (
+            physical_to_logical < self.num_logical_experts
+        )
+        indices = physical_to_logical.masked_fill(~valid_mask, 0).to(torch.int64)
+        logical_count = torch.zeros(
+            (self.num_layers, self.num_logical_experts),
+            dtype=global_physical_count.dtype,
+            device=global_physical_count.device,
+        )
+        logical_count.scatter_add_(
+            1,
+            indices,
+            global_physical_count * valid_mask.to(global_physical_count.dtype),
+        )
+        return logical_count
+
+    def _compute_rank_count_from_global_physical_count(
+        self,
+        global_physical_count: torch.Tensor,
+        physical_expert_owner_ep_rank: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        if global_physical_count.ndim != 3:
+            raise ValueError(
+                "global_physical_count must be [time, layer, physical_expert], got "
+                f"{global_physical_count.shape}."
+            )
+        if physical_expert_owner_ep_rank is None:
+            physical_expert_owner_ep_rank = self.physical_expert_owner_ep_rank_cpu
+        physical_owner = physical_expert_owner_ep_rank.to(device=global_physical_count.device)
+        rank_count = torch.zeros(
+            (global_physical_count.shape[0], global_physical_count.shape[1], self.ep_size),
+            dtype=global_physical_count.dtype,
+            device=global_physical_count.device,
+        )
+        for ep_rank in range(self.ep_size):
+            owner_mask = (physical_owner == ep_rank).to(global_physical_count.dtype)
+            rank_count[:, :, ep_rank] = (
+                global_physical_count * owner_mask.unsqueeze(0)
+            ).sum(dim=2)
+        return rank_count
+
+    def _compute_rank_count_if_unambiguous(
+        self, logical_count: torch.Tensor
+    ) -> torch.Tensor | None:
+        if self.ep_size <= 1:
+            return torch.zeros(
+                (logical_count.shape[0], logical_count.shape[1], 1),
+                dtype=logical_count.dtype,
+            )
+        if torch.any(self.logical_to_all_physical_map_num_valid_cpu > 1):
+            return None
+
+        logical_owner = torch.full(
+            (self.num_layers, self.num_logical_experts), -1, dtype=torch.int64
+        )
+        valid_mask = self.logical_to_all_physical_map_num_valid_cpu > 0
+        if valid_mask.any():
+            first_physical = self.logical_to_all_physical_map_cpu[..., 0].clamp_min(0)
+            owner_values = torch.gather(
+                self.physical_expert_owner_ep_rank_cpu, 1, first_physical
+            )
+            logical_owner[valid_mask] = owner_values[valid_mask]
+
+        rank_count = torch.zeros(
+            (logical_count.shape[0], logical_count.shape[1], self.ep_size),
+            dtype=logical_count.dtype,
+        )
+        for ep_rank in range(self.ep_size):
+            owner_mask = (logical_owner == ep_rank).to(logical_count.dtype)
+            rank_count[:, :, ep_rank] = (
+                logical_count * owner_mask.unsqueeze(0)
+            ).sum(dim=2)
+        return rank_count
+
+    def _build_request_spans(
+        self,
+        req_ids: list[str],
+        num_scheduled_tokens: list[int],
+        num_computed_tokens_before: list[int],
+        num_prompt_tokens: list[int],
+    ) -> tuple[list[dict[str, Any]], list[str], list[int]]:
+        spans: list[dict[str, Any]] = []
+        token_request_ids: list[str] = []
+        token_forward_modes: list[int] = []
+        token_start = 0
+
+        for req_id, num_sched, num_computed, num_prompt in zip(
+            req_ids,
+            num_scheduled_tokens,
+            num_computed_tokens_before,
+            num_prompt_tokens,
+            strict=True,
+        ):
+            num_sched = int(num_sched)
+            if num_sched <= 0:
+                continue
+
+            prompt_remaining = max(int(num_prompt) - int(num_computed), 0)
+            prompt_part = min(num_sched, prompt_remaining)
+            decode_part = num_sched - prompt_part
+            token_end = token_start + num_sched
+
+            spans.append(
+                dict(
+                    req_id=req_id,
+                    token_start=token_start,
+                    token_end=token_end,
+                    num_scheduled_tokens=num_sched,
+                    num_computed_tokens_before=int(num_computed),
+                    num_prompt_tokens=int(num_prompt),
+                    prompt_part_tokens=prompt_part,
+                    decode_part_tokens=decode_part,
+                )
+            )
+            token_request_ids.extend([req_id] * num_sched)
+            token_forward_modes.extend([1] * prompt_part)
+            token_forward_modes.extend([2] * decode_part)
+            token_start = token_end
+
+        return spans, token_request_ids, token_forward_modes
+
+    @staticmethod
+    def _infer_forward_mode(token_forward_modes: list[int]) -> int:
+        if not token_forward_modes:
+            return 2
+        has_prefill = any(mode == 1 for mode in token_forward_modes)
+        if has_prefill:
+            return 1
+        return 2
+
+    def _build_stat_payload(self) -> dict[str, Any]:
+        num_steps = len(self._forward_pass_ids)
+        if num_steps == 0:
+            global_physical_count = torch.zeros(
+                (0, self.num_layers, self.num_physical_experts), dtype=torch.int32
+            )
+            logical_count = torch.zeros(
+                (0, self.num_layers, self.num_logical_experts), dtype=torch.int32
+            )
+            rank_count = torch.zeros((0, self.num_layers, self.ep_size), dtype=torch.int32)
+            segments: list[dict[str, Any]] = []
+        else:
+            segment_ranges: list[tuple[int, int]] = []
+            seg_start = 0
+            for idx in range(1, num_steps):
+                if not (
+                    torch.equal(
+                        self._physical_to_logical_map_steps[idx - 1],
+                        self._physical_to_logical_map_steps[idx],
+                    )
+                    and torch.equal(
+                        self._logical_to_all_physical_map_steps[idx - 1],
+                        self._logical_to_all_physical_map_steps[idx],
+                    )
+                    and torch.equal(
+                        self._logical_to_all_physical_map_num_valid_steps[idx - 1],
+                        self._logical_to_all_physical_map_num_valid_steps[idx],
+                    )
+                    and torch.equal(
+                        self._physical_expert_owner_ep_rank_steps[idx - 1],
+                        self._physical_expert_owner_ep_rank_steps[idx],
+                    )
+                ):
+                    segment_ranges.append((seg_start, idx))
+                    seg_start = idx
+            segment_ranges.append((seg_start, num_steps))
+
+            segments = []
+            global_physical_count_parts: list[torch.Tensor] = []
+            logical_count_parts: list[torch.Tensor] = []
+            rank_count_parts: list[torch.Tensor] = []
+
+            for segment_index, (start, end) in enumerate(segment_ranges):
+                segment_global_physical_count = torch.stack(
+                    self._global_physical_count_steps[start:end], dim=0
+                )
+                segment_logical_count = torch.stack(
+                    self._logical_count_steps[start:end], dim=0
+                )
+                segment_physical_owner = self._physical_expert_owner_ep_rank_steps[start]
+                segment_rank_count = self._compute_rank_count_from_global_physical_count(
+                    segment_global_physical_count,
+                    physical_expert_owner_ep_rank=segment_physical_owner,
+                )
+
+                global_physical_count_parts.append(segment_global_physical_count)
+                logical_count_parts.append(segment_logical_count)
+                rank_count_parts.append(segment_rank_count)
+
+                segments.append(
+                    dict(
+                        segment_index=segment_index,
+                        num_steps=end - start,
+                        forward_pass_ids=list(self._forward_pass_ids[start:end]),
+                        forward_modes=list(self._forward_modes[start:end]),
+                        global_forward_modes=list(
+                            self._global_forward_modes[start:end]
+                        ),
+                        is_extend_in_batch=list(self._is_extend_in_batch[start:end]),
+                        forward_request_ids=list(self._forward_request_ids[start:end]),
+                        forward_request_spans=list(
+                            self._forward_request_spans[start:end]
+                        ),
+                        global_physical_count=segment_global_physical_count.clone(),
+                        logical_count=segment_logical_count.clone(),
+                        rank_count=segment_rank_count.clone(),
+                        physical_to_logical_map=(
+                            self._physical_to_logical_map_steps[start].clone()
+                        ),
+                        logical_to_all_physical_map=(
+                            self._logical_to_all_physical_map_steps[start].clone()
+                        ),
+                        logical_to_all_physical_map_num_valid=(
+                            self._logical_to_all_physical_map_num_valid_steps[start]
+                            .clone()
+                        ),
+                        physical_expert_owner_ep_rank=(
+                            self._physical_expert_owner_ep_rank_steps[start].clone()
+                        ),
+                    )
+                )
+
+            global_physical_count = torch.cat(global_physical_count_parts, dim=0)
+            logical_count = torch.cat(logical_count_parts, dim=0)
+            rank_count = torch.cat(rank_count_parts, dim=0)
+
+        return dict(
+            rank=self.global_rank,
+            global_physical_count=global_physical_count,
+            logical_count=logical_count,
+            rank_count=rank_count,
+            forward_pass_ids=list(self._forward_pass_ids),
+            forward_modes=list(self._forward_modes),
+            global_forward_modes=list(self._global_forward_modes),
+            is_extend_in_batch=list(self._is_extend_in_batch),
+            forward_request_ids=list(self._forward_request_ids),
+            forward_request_spans=list(self._forward_request_spans),
+            segments=segments,
+            ep_size=self.ep_size,
+            num_layers=self.num_layers,
+            num_physical_experts=self.num_physical_experts,
+            num_local_physical_experts=self.num_local_physical_experts,
+            num_logical_experts=self.num_logical_experts,
+            last_physical_to_logical_map=self.physical_to_logical_map_cpu.clone(),
+            physical_expert_owner_ep_rank=self.physical_expert_owner_ep_rank_cpu.clone(),
+            average_utilization_rate_over_window=None,
+            data_parallel_rank=self.data_parallel_rank,
+            pipeline_parallel_rank=self.pipeline_parallel_rank,
+            tensor_parallel_rank=self.tensor_parallel_rank,
