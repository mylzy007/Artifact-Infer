index 000000000..b2b373da1
--- /dev/null
+++ b/tests/kernels/moe/modular_kernel_tools/benchmark_eplb_multigpu.py
@@ -0,0 +1,1212 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""
+Benchmark single-layer MoE modular-kernel performance under synthetic routing.
+
+This script intentionally does not simulate attention or request scheduling.
+Instead, it directly constructs the routing result for one MoE layer and
+measures the end-to-end time of that layer.
+
+Two routing spaces are supported:
+
+1) physical_gpu (default)
+   Directly control the final physical-GPU token distribution.
+   This is the strictest mode if you want "GPU0/GPU1/... receives what share
+   of routed tokens". To keep that guarantee exact, this mode only supports
+   --mode off.
+
+2) logical_owner
+   Legacy mode: control routing bias in logical-expert owner space. This can
+   still be used together with EPLB on/off experiments.
+"""
+
+import argparse
+import json
+import math
+import os
+import random
+from dataclasses import dataclass
+
+import torch
+
+from tests.kernels.moe.modular_kernel_tools.parallel_utils import (
+    ProcessGroupInfo,
+    parallel_launch_with_config,
+)
+from tests.kernels.moe.utils import make_test_weights
+from vllm.config import CompilationConfig, ParallelConfig, VllmConfig, set_current_vllm_config
+from vllm.distributed.eplb.eplb_communicator import create_eplb_communicator
+from vllm.distributed.eplb.eplb_state import EplbState, compute_logical_maps
+from vllm.distributed.eplb.rebalance_execute import rearrange_expert_weights_inplace
+from vllm.distributed.parallel_state import get_eplb_group
+from vllm.forward_context import set_forward_context
+from vllm.model_executor.layers.fused_moe.layer import FusedMoE
+from vllm.utils.torch_utils import set_random_seed
+from vllm.v1.worker.workspace import (
+    init_workspace_manager,
+    is_workspace_manager_initialized,
+)
+
+
+@dataclass
+class BenchArgs:
+    world_size: int
+    backend: str
+    routing_space: str
+    logical_num_experts: int
+    num_redundant_experts: int
+    topk: int
+    hidden_size: int
+    intermediate_size: int
+    tokens_per_rank: list[int]
+    dest_rank_matrix: list[list[float]] | None
+    physical_rank_probs: list[float] | None
+    trial_id: int | None
+    target_dest_cv: float | None
+    target_dest_std: float | None
+    target_dest_entropy: float | None
+    routing_pattern: str
+    hot_token_frac: float
+    hot_expert_frac: float
+    warmup_iters: int
+    iters: int
+    seed: int
+    require_modular: bool
+    output_json: str | None
+    verbose: bool
+
+
+@dataclass
+class BenchCase:
+    name: str
+    enable_eplb: bool
+
+
+def _split_range(total: int, world: int, rank: int) -> tuple[int, int]:
+    base = total // world
+    rem = total % world
+    start = rank * base + min(rank, rem)
+    end = start + base + (1 if rank < rem else 0)
+    return start, end
+
+
+def _parse_int_list(s: str) -> list[int]:
+    out = [int(x.strip()) for x in s.split(",") if x.strip()]
+    if len(out) == 0:
+        raise ValueError("Expected a non-empty comma-separated list")
+    return out
+
+
+def _parse_float_matrix(s: str, world_size: int) -> list[list[float]]:
+    rows = []
+    for row_text in s.split("/"):
+        row = [float(x.strip()) for x in row_text.split(",") if x.strip()]
+        if row:
+            rows.append(row)
+    if len(rows) != world_size:
+        raise ValueError(
+            f"dest-rank matrix must have {world_size} rows, got {len(rows)}"
+        )
+    out: list[list[float]] = []
+    for row_idx, row in enumerate(rows):
+        if len(row) != world_size:
+            raise ValueError(
+                f"dest-rank matrix row {row_idx} must have {world_size} columns, "
+                f"got {len(row)}"
+            )
+        if any(x < 0 for x in row):
+            raise ValueError("dest-rank matrix values must be >= 0")
+        total = sum(row)
+        if total <= 0:
+            raise ValueError("each dest-rank matrix row must sum to > 0")
+        out.append([x / total for x in row])
+    return out
+
+
+def _parse_float_probs(s: str, world_size: int) -> list[float]:
+    probs = [float(x.strip()) for x in s.split(",") if x.strip()]
+    if len(probs) != world_size:
+        raise ValueError(
+            f"probability list must have {world_size} items, got {len(probs)}"
+        )
+    if any(x < 0 for x in probs):
+        raise ValueError("probability values must be >= 0")
+    total = sum(probs)
+    if total <= 0:
+        raise ValueError("probability values must sum to > 0")
+    return [x / total for x in probs]
+
+
+def _build_logical_experts_by_rank(
+    logical_num_experts: int,
+    world_size: int,
+) -> list[torch.Tensor]:
+    experts_by_rank: list[torch.Tensor] = []
+    for owner_rank in range(world_size):
+        s, e = _split_range(logical_num_experts, world_size, owner_rank)
+        experts = torch.arange(s, e, dtype=torch.long)
+        if experts.numel() == 0:
+            experts = torch.arange(logical_num_experts, dtype=torch.long)
+        experts_by_rank.append(experts)
+    return experts_by_rank
+
+
+def _prob_std(probs: list[float]) -> float:
+    mean = sum(probs) / len(probs)
+    return math.sqrt(sum((x - mean) ** 2 for x in probs) / len(probs))
+
+
+def _prob_cv(probs: list[float]) -> float:
+    mean = sum(probs) / len(probs)
+    if mean <= 0:
+        return 0.0
+    return _prob_std(probs) / mean
+
+
+def _prob_entropy_normalized(probs: list[float]) -> float:
+    eps = 1e-12
+    entropy = -sum(x * math.log(max(x, eps)) for x in probs if x > 0)
+    max_entropy = math.log(len(probs))
+    if max_entropy <= 0:
+        return 0.0
+    return entropy / max_entropy
+
+
+def _split_total_tokens(total_tokens: int, world_size: int) -> list[int]:
+    base = total_tokens // world_size
+    rem = total_tokens % world_size
+    return [base + (1 if i < rem else 0) for i in range(world_size)]
+
+
+def _sample_dest_probs_by_stats(
+    world_size: int,
+    target_std: float | None,
+    target_entropy: float | None,
+    sample_attempts: int,
+    seed: int,
+) -> list[float]:
+    if target_std is None and target_entropy is None:
+        raise ValueError("At least one of target_std/target_entropy must be set")
+
+    rng = random.Random(seed)
+
+    best_probs: list[float] | None = None
+    best_score = float("inf")
+    for _ in range(sample_attempts):
+        log_alpha = rng.uniform(-2.0, 2.0)
+        alpha_scalar = 10.0 ** log_alpha
+        gammas = [rng.gammavariate(alpha_scalar, 1.0) for _ in range(world_size)]
+        total_gamma = sum(gammas)
+        if total_gamma <= 0:
+            continue
+        probs = [x / total_gamma for x in gammas]
+        cur_std = _prob_std(probs)
+        cur_entropy = _prob_entropy_normalized(probs)
+
+        score = 0.0
+        if target_std is not None:
+            denom = max(abs(target_std), 1e-6)
+            score += ((cur_std - target_std) / denom) ** 2
+        if target_entropy is not None:
+            denom = max(abs(target_entropy), 1e-6)
+            score += ((cur_entropy - target_entropy) / denom) ** 2
+        if score < best_score:
+            best_score = score
+            best_probs = probs
+
+    assert best_probs is not None
+    total = sum(best_probs)
+    return [x / total for x in best_probs]
+
+
+def _counts_from_probs(total: int, probs: list[float]) -> list[int]:
+    raw = [total * p for p in probs]
+    counts = [int(math.floor(x)) for x in raw]
+    remainder = total - sum(counts)
+    order = sorted(
+        range(len(probs)),
+        key=lambda i: (raw[i] - counts[i], -i),
+        reverse=True,
+    )
+    for i in range(remainder):
+        counts[order[i]] += 1
+    return counts
+
+
+def _build_rank_major_slot_targets(
+    local_tokens: int,
+    topk: int,
+    rank_probs: list[float],
+    rng: torch.Generator,
+) -> torch.Tensor:
+    total_slots = local_tokens * topk
+    counts = _counts_from_probs(total_slots, rank_probs)
+    slots = []
+    for owner_rank, count in enumerate(counts):
+        slots.extend([owner_rank] * count)
+    slot_tensor = torch.tensor(slots, dtype=torch.long)
+    perm = torch.randperm(slot_tensor.numel(), generator=rng)
+    return slot_tensor[perm].view(local_tokens, topk)
+
+
+def _make_routing_ids(
+    local_tokens: int,
+    topk: int,
+    logical_num_experts: int,
+    world_size: int,
+    rank: int,
+    routing_space: str,
+    dest_rank_matrix: list[list[float]] | None,
+    physical_rank_probs: list[float] | None,
+    pattern: str,
+    hot_token_frac: float,
+    hot_expert_frac: float,
+    seed: int,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    assert topk <= logical_num_experts
+
+    rng = torch.Generator(device="cpu")
+    rng.manual_seed(seed + 104729 * (rank + 1))
+
+    all_experts = torch.arange(logical_num_experts, dtype=torch.long)
+    all_expert_ids = [int(x) for x in all_experts.tolist()]
+    experts_by_rank = _build_logical_experts_by_rank(logical_num_experts, world_size)
+    hot_experts_by_rank: list[torch.Tensor] = []
+    expert_ids_by_rank: list[list[int]] = []
+    hot_expert_ids_by_rank: list[list[int]] = []
+    for experts in experts_by_rank:
+        expert_ids = [int(x) for x in experts.tolist()]
+        expert_ids_by_rank.append(expert_ids)
+        # Let hot_expert_frac control the actual hot subset size, even when it
+        # is smaller than topk. When the hot pool is exhausted for a token, the
+        # selection logic below naturally falls back to the remaining experts on
+        # the same owner rank.
+        hot_count = int(round(experts.numel() * hot_expert_frac))
+        hot_count = min(max(hot_count, 1), experts.numel())
+        hot_experts = experts[
+            torch.randperm(experts.numel(), generator=rng)[:hot_count]
+        ]
+        hot_experts_by_rank.append(hot_experts)
+        hot_expert_ids_by_rank.append([int(x) for x in hot_experts.tolist()])
+
+    ids = torch.empty((local_tokens, topk), dtype=torch.long)
+    if routing_space == "physical_gpu":
+        if physical_rank_probs is None:
+            raise ValueError("physical_gpu routing requires physical_rank_probs")
+        rank_slots = _build_rank_major_slot_targets(
+            local_tokens=local_tokens,
+            topk=topk,
+            rank_probs=physical_rank_probs,
+            rng=rng,
+        )
+        for i in range(local_tokens):
+            selected: list[int] = []
+            used = set()
+            for j in range(topk):
+                owner_rank = int(rank_slots[i, j].item())
+                use_hot = torch.rand((), generator=rng).item() < hot_token_frac
+                pool = (
+                    hot_expert_ids_by_rank[owner_rank]
+                    if use_hot
+                    else expert_ids_by_rank[owner_rank]
+                )
+                candidate_pool = [x for x in pool if x not in used]
+                if not candidate_pool:
+                    candidate_pool = [x for x in expert_ids_by_rank[owner_rank] if x not in used]
+                if not candidate_pool:
+                    candidate_pool = [x for x in all_expert_ids if x not in used]
+                if not candidate_pool:
+                    candidate_pool = all_expert_ids
+                pick_idx = int(
+                    torch.randint(len(candidate_pool), (1,), generator=rng).item()
+                )
+                expert_id = candidate_pool[pick_idx]
+                used.add(expert_id)
+                selected.append(expert_id)
+            ids[i] = torch.tensor(selected, dtype=torch.long)
+    else:
+        rank_probs: list[float] | None = None
+        if dest_rank_matrix is not None:
+            rank_probs = dest_rank_matrix[rank]
+        elif pattern == "uniform":
+            rank_probs = [1.0 / world_size for _ in range(world_size)]
+        elif pattern == "rank0_hot":
+            rank_probs = [0.0 for _ in range(world_size)]
+            rank_probs[0] = 1.0
+        elif pattern == "rank_local_hot":
+            rank_probs = [0.0 for _ in range(world_size)]
+            rank_probs[rank] = 1.0
+        else:
+            raise ValueError(f"Unsupported routing pattern: {pattern}")
+        rank_probs_t = torch.tensor(rank_probs, dtype=torch.float64)
+        rank_probs_t = rank_probs_t / rank_probs_t.sum()
+
+        for i in range(local_tokens):
+            selected = []
+            used = set()
+            for _ in range(topk):
+                use_hot = torch.rand((), generator=rng).item() < hot_token_frac
+                owner_rank = int(torch.multinomial(rank_probs_t, 1, generator=rng).item())
+                pool = (
+                    hot_expert_ids_by_rank[owner_rank]
+                    if use_hot
+                    else expert_ids_by_rank[owner_rank]
+                )
+                candidate_pool = [x for x in pool if x not in used]
+                if not candidate_pool:
+                    candidate_pool = [x for x in all_expert_ids if x not in used]
+                if not candidate_pool:
+                    candidate_pool = all_expert_ids
+                pick_idx = int(
+                    torch.randint(len(candidate_pool), (1,), generator=rng).item()
+                )
+                expert_id = candidate_pool[pick_idx]
+                used.add(expert_id)
+                selected.append(expert_id)
+            ids[i] = torch.tensor(selected, dtype=torch.long)
+
+    weights = torch.full((local_tokens, topk), 1.0 / topk, dtype=torch.float32)
+    return ids, weights
+
+
+def _build_rebalanced_physical_to_logical(
+    logical_load: torch.Tensor,
+    num_redundant_experts: int,
+) -> torch.Tensor:
+    """
+    Build a target physical->logical layout:
+    1) allocate extra replicas to logical experts using greedy max-load split
+    2) interleave physical slots by greedy load-per-replica score
+    """
+    assert logical_load.ndim == 1
+    num_logical = logical_load.numel()
+    num_physical = num_logical + num_redundant_experts
+
+    replicas = torch.ones((num_logical,), dtype=torch.long)
+    if num_redundant_experts > 0:
+        logical_load_f = logical_load.to(torch.float64)
+        for _ in range(num_redundant_experts):
+            score = logical_load_f / (replicas.to(torch.float64) + 1.0)
+            idx = int(torch.argmax(score).item())
+            replicas[idx] += 1
+
+    assigned = torch.zeros_like(replicas)
+    out = []
+    logical_load_f = logical_load.to(torch.float64)
+    for _ in range(num_physical):
+        valid = assigned < replicas
+        score = logical_load_f / (assigned.to(torch.float64) + 1.0)
+        score[~valid] = -1.0
+        idx = int(torch.argmax(score).item())
+        assigned[idx] += 1
+        out.append(idx)
+
+    return torch.tensor(out, dtype=torch.long, device="cpu")
+
+
+def _make_vllm_config(world_size: int, backend: str, enable_eplb: bool) -> VllmConfig:
+    parallel_config = ParallelConfig(
+        pipeline_parallel_size=1,
+        data_parallel_size=world_size,
+        tensor_parallel_size=1,
+        enable_expert_parallel=True,
+        all2all_backend=backend,
+        enable_eplb=enable_eplb,
+    )
+    compilation_config = CompilationConfig()
+    compilation_config.pass_config.fuse_allreduce_rms = False
+    return VllmConfig(
+        parallel_config=parallel_config,
+        compilation_config=compilation_config,
+    )
+
+
+def _run_case_worker(
+    pgi: ProcessGroupInfo,
+    vllm_config: VllmConfig,
+    cpu_group,
+    bench: BenchArgs,
+    case: BenchCase,
+) -> None:
+    set_random_seed(bench.seed + pgi.rank)
+
+    device = torch.accelerator.current_accelerator()
+    if not is_workspace_manager_initialized():
+        init_workspace_manager(device)
+
+    local_tokens = bench.tokens_per_rank[pgi.rank]
+    assert local_tokens > 0, "tokens per rank must all be > 0"
+
+    if case.enable_eplb:
+        physical_num_experts = bench.logical_num_experts + bench.num_redundant_experts
+    else:
+        physical_num_experts = bench.logical_num_experts
+
+    if physical_num_experts % bench.world_size != 0:
+        raise ValueError(
+            f"num physical experts ({physical_num_experts}) must be divisible by "
+            f"world size ({bench.world_size})"
+        )
+
+    # Build global logical weights then expand to physical by old EPLB map
+    # so redundant experts start as exact replicas.
+    (logical_w1, _, _, _), (logical_w2, _, _, _) = make_test_weights(
+        e=bench.logical_num_experts,
+        n=bench.intermediate_size,
+        k=bench.hidden_size,
+        in_dtype=torch.bfloat16,
+    )
+
+    if case.enable_eplb:
+        old_map = torch.tensor(
+            EplbState.build_initial_global_physical_to_logical_map(
+                bench.logical_num_experts, bench.num_redundant_experts
+            ),
+            dtype=torch.long,
+            device=logical_w1.device,
+        )
+    else:
+        old_map = torch.arange(
+            bench.logical_num_experts, dtype=torch.long, device=logical_w1.device
+        )
+
+    physical_w1 = logical_w1.index_select(0, old_map).contiguous()
+    physical_w2 = logical_w2.index_select(0, old_map).contiguous()
+
+    local_num_experts = physical_num_experts // bench.world_size
+    s = pgi.rank * local_num_experts
+    e = s + local_num_experts
+    local_w1 = physical_w1[s:e].to(device=device)
+    local_w2 = physical_w2[s:e].to(device=device)
+
+    hidden_states = (
+        torch.randn((local_tokens, bench.hidden_size), device=device, dtype=torch.bfloat16)
+        / 10.0
+    )
+    # Custom routing ignores router logits, keep it cheap and deterministic.
+    router_logits = torch.zeros(
+        (local_tokens, bench.logical_num_experts), device=device, dtype=torch.bfloat16
+    )
+
+    topk_ids_cpu, topk_weights_cpu = _make_routing_ids(
+        local_tokens=local_tokens,
+        topk=bench.topk,
+        logical_num_experts=bench.logical_num_experts,
+        world_size=bench.world_size,
+        rank=pgi.rank,
+        routing_space=bench.routing_space,
+        dest_rank_matrix=bench.dest_rank_matrix,
+        physical_rank_probs=bench.physical_rank_probs,
+        pattern=bench.routing_pattern,
+        hot_token_frac=bench.hot_token_frac,
+        hot_expert_frac=bench.hot_expert_frac,
+        seed=bench.seed,
+    )
+    topk_ids = topk_ids_cpu.to(device=device)
+    topk_weights = topk_weights_cpu.to(device=device)
+
+    def _custom_routing_function(
+        hidden_states: torch.Tensor,
+        gating_output: torch.Tensor,
+        topk: int,
+        renormalize: bool,
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        del gating_output, topk, renormalize
+        if hidden_states.shape[0] != topk_ids.shape[0]:
+            raise RuntimeError(
+                "Input token count changed. This benchmark expects a fixed "
+                "per-rank token count."
+            )
+        return topk_weights, topk_ids
+
+    with set_current_vllm_config(vllm_config):
+        layer = FusedMoE(
+            num_experts=bench.logical_num_experts,
+            num_redundant_experts=bench.num_redundant_experts if case.enable_eplb else 0,
+            top_k=bench.topk,
+            hidden_size=bench.hidden_size,
+            intermediate_size=bench.intermediate_size,
+            params_dtype=torch.bfloat16,
+            tp_size=1,
+            ep_size=bench.world_size,
+            dp_size=bench.world_size,
+            reduce_results=False,
+            custom_routing_function=_custom_routing_function,
+            enable_eplb=case.enable_eplb,
+            prefix=f"bench_{case.name}_rank_{pgi.rank}",
+        )
+
+        layer.register_parameter(
+            "w13_weight", torch.nn.Parameter(local_w1, requires_grad=False)
+        )
+        layer.register_parameter(
+            "w2_weight", torch.nn.Parameter(local_w2, requires_grad=False)
+        )
+        layer.quant_method.process_weights_after_loading(layer)
+        layer.maybe_init_modular_kernel()
+        if layer._expert_map is not None:
+            layer._expert_map = layer._expert_map.to(device)
+
+        moe_kernel = getattr(layer.quant_method, "moe_kernel", None)
+        is_modular_kernel = moe_kernel is not None and not moe_kernel.is_monolithic
+        if bench.require_modular and not is_modular_kernel:
+            raise RuntimeError(
+                "This run did not use FusedMoE modular kernel. "
+                f"Current quant method: {layer.quant_method.__class__.__name__}; "
+                f"moe_kernel={type(moe_kernel).__name__ if moe_kernel is not None else None}"
+            )
+
+        logical_hist = torch.bincount(
+            topk_ids.view(-1).to(torch.int64), minlength=bench.logical_num_experts
+        ).to(device=device, dtype=torch.int64)
+        torch.distributed.all_reduce(logical_hist, op=torch.distributed.ReduceOp.SUM)
+
+        if case.enable_eplb:
+            communicator = create_eplb_communicator(
+                group_coordinator=get_eplb_group(),
+                backend=vllm_config.parallel_config.eplb_config.communicator,
+                expert_weights=list(layer.get_expert_weights()),
+            )
+
+            old_global_expert_indices = old_map.to(dtype=torch.long, device="cpu").unsqueeze(0)
+            new_global_expert_indices = _build_rebalanced_physical_to_logical(
+                logical_load=logical_hist.to(device="cpu"),
+                num_redundant_experts=bench.num_redundant_experts,
+            ).unsqueeze(0)
+
+            rearrange_expert_weights_inplace(
+                old_global_expert_indices=old_global_expert_indices,
+                new_global_expert_indices=new_global_expert_indices,
+                expert_weights=[list(layer.get_expert_weights())],
+                ep_group=cpu_group,
+                communicator=communicator,
+            )
+
+            logical_to_physical_cpu, logical_replica_count_cpu = compute_logical_maps(
+                new_global_expert_indices.squeeze(0), bench.logical_num_experts
+            )
+            layer.set_eplb_state(
+                moe_layer_idx=0,
+                expert_load_view=torch.zeros(
+                    (1, physical_num_experts), dtype=torch.int32, device=device
+                ),
+                logical_to_physical_map=logical_to_physical_cpu.to(
+                    device=device, dtype=torch.int32
+                ).unsqueeze(0),
+                logical_replica_count=logical_replica_count_cpu.to(
+                    device=device, dtype=torch.int32
+                ).unsqueeze(0),
+            )
+            layer.eplb_state.should_record_tensor = torch.zeros(
+                (), dtype=torch.bool, device=device
+            )
+
+        local_tokens_tensor = torch.tensor([local_tokens], device=device, dtype=torch.int32)
+        tokens_by_rank = [torch.zeros_like(local_tokens_tensor) for _ in range(bench.world_size)]
+        torch.distributed.all_gather(tokens_by_rank, local_tokens_tensor)
+        num_tokens_across_dp = torch.cat(tokens_by_rank).to(dtype=torch.int32)
+
+        for _ in range(bench.warmup_iters):
+            with set_forward_context(
+                None,
+                vllm_config,
+                num_tokens=local_tokens,
+                num_tokens_across_dp=num_tokens_across_dp,
+            ):
+                _ = layer(hidden_states, router_logits)
+        torch.accelerator.synchronize()
+
+        if case.enable_eplb:
+            assert layer.eplb_state.expert_load_view is not None
+            layer.eplb_state.expert_load_view.zero_()
+            assert layer.eplb_state.should_record_tensor is not None
+            layer.eplb_state.should_record_tensor.fill_(True)
+
+        lat_ms: list[float] = []
+        for _ in range(bench.iters):
+            st = torch.cuda.Event(enable_timing=True)
+            ed = torch.cuda.Event(enable_timing=True)
+            st.record()
+            with set_forward_context(
+                None,
+                vllm_config,
+                num_tokens=local_tokens,
+                num_tokens_across_dp=num_tokens_across_dp,
+            ):
+                _ = layer(hidden_states, router_logits)
+            ed.record()
+            ed.synchronize()
+            lat_ms.append(st.elapsed_time(ed))
+
+        local_mean_ms = float(sum(lat_ms) / len(lat_ms))
+        local_mean_t = torch.tensor([local_mean_ms], device=device, dtype=torch.float64)
+        max_mean_t = local_mean_t.clone()
+        torch.distributed.all_reduce(max_mean_t, op=torch.distributed.ReduceOp.MAX)
+
+        total_tokens_t = torch.tensor([float(local_tokens)], device=device, dtype=torch.float64)
+        torch.distributed.all_reduce(total_tokens_t, op=torch.distributed.ReduceOp.SUM)
+        global_toks_per_s = float(total_tokens_t.item() / (max_mean_t.item() / 1000.0))
+
+        gathered_means = [torch.zeros_like(local_mean_t) for _ in range(bench.world_size)]
+        torch.distributed.all_gather(gathered_means, local_mean_t)
+        per_rank_mean_ms = [float(x.item()) for x in gathered_means]
+
+        if case.enable_eplb:
+            assert layer.eplb_state.expert_load_view is not None
+            physical_hist = layer.eplb_state.expert_load_view.to(torch.int64).clone()
+            torch.distributed.all_reduce(physical_hist, op=torch.distributed.ReduceOp.SUM)
+            physical_hist_list = physical_hist.tolist()
+        else:
+            physical_hist_list = logical_hist.tolist()
+
+        if pgi.rank == 0:
+            sampled_dest_probs = None
+            sampled_dest_cv = None
+            sampled_dest_std = None
+            sampled_dest_entropy = None
+            sampled_physical_probs = None
+            sampled_physical_cv = None
+            sampled_physical_std = None
+            sampled_physical_entropy = None
+            if bench.dest_rank_matrix is not None and len(bench.dest_rank_matrix) > 0:
+                sampled_dest_probs = [float(x) for x in bench.dest_rank_matrix[0]]
+                sampled_dest_cv = _prob_cv(sampled_dest_probs)
+                sampled_dest_std = _prob_std(sampled_dest_probs)
+                sampled_dest_entropy = _prob_entropy_normalized(sampled_dest_probs)
+            if bench.physical_rank_probs is not None:
+                sampled_physical_probs = [float(x) for x in bench.physical_rank_probs]
+                sampled_physical_cv = _prob_cv(sampled_physical_probs)
+                sampled_physical_std = _prob_std(sampled_physical_probs)
+                sampled_physical_entropy = _prob_entropy_normalized(
+                    sampled_physical_probs
+                )
+            realized_physical_rank_counts = []
+            local_num_experts = physical_num_experts // bench.world_size
+            for owner_rank in range(bench.world_size):
+                s = owner_rank * local_num_experts
+                e = s + local_num_experts
+                realized_physical_rank_counts.append(sum(physical_hist_list[s:e]))
+            realized_total = max(sum(realized_physical_rank_counts), 1)
+            realized_physical_rank_probs = [
+                float(x) / float(realized_total) for x in realized_physical_rank_counts
+            ]
+            result = {
+                "benchmark_scope": "single_moe_layer_e2e",
+                "case": case.name,
+                "enable_eplb": case.enable_eplb,
+                "trial_id": bench.trial_id,
+                "world_size": bench.world_size,
+                "backend": bench.backend,
+                "routing_space": bench.routing_space,
+                "num_logical_experts": bench.logical_num_experts,
+                "num_redundant_experts": (
+                    bench.num_redundant_experts if case.enable_eplb else 0
+                ),
+                "num_physical_experts": physical_num_experts,
+                "topk": bench.topk,
+                "hidden_size": bench.hidden_size,
+                "intermediate_size": bench.intermediate_size,
+                "tokens_per_rank": bench.tokens_per_rank,
+                "dest_rank_matrix": bench.dest_rank_matrix,
+                "physical_rank_probs": bench.physical_rank_probs,
+                "sampled_dest_rank_probs": sampled_dest_probs,
+                "sampled_dest_cv": sampled_dest_cv,
+                "sampled_dest_std": sampled_dest_std,
+                "sampled_dest_entropy": sampled_dest_entropy,
+                "sampled_physical_rank_probs": sampled_physical_probs,
+                "sampled_physical_cv": sampled_physical_cv,
+                "sampled_physical_std": sampled_physical_std,
+                "sampled_physical_entropy": sampled_physical_entropy,
+                "target_dest_cv": bench.target_dest_cv,
+                "target_dest_std": bench.target_dest_std,
+                "target_dest_entropy": bench.target_dest_entropy,
+                "routing_pattern": bench.routing_pattern,
+                "hot_token_frac": bench.hot_token_frac,
+                "hot_expert_frac": bench.hot_expert_frac,
+                "iters": bench.iters,
+                "warmup_iters": bench.warmup_iters,
+                "max_rank_mean_step_ms": float(max_mean_t.item()),
+                "per_rank_mean_step_ms": per_rank_mean_ms,
+                "global_tokens_per_s": global_toks_per_s,
+                "logical_token_hist_total": logical_hist.tolist(),
+                "physical_token_hist_total": physical_hist_list,
+                "realized_physical_rank_counts": realized_physical_rank_counts,
+                "realized_physical_rank_probs": realized_physical_rank_probs,
+                "realized_physical_cv": _prob_cv(realized_physical_rank_probs),
+                "realized_physical_std": _prob_std(realized_physical_rank_probs),
+                "realized_physical_entropy": _prob_entropy_normalized(
+                    realized_physical_rank_probs
+                ),
+            }
+
+            print(json.dumps(result, ensure_ascii=False))
+            if bench.output_json is not None:
+                out_dir = os.path.dirname(bench.output_json)
+                if out_dir:
+                    os.makedirs(out_dir, exist_ok=True)
+                with open(bench.output_json, "a", encoding="utf-8") as f:
+                    f.write(json.dumps(result, ensure_ascii=False) + "\n")
+
+
+def _run_case(bench: BenchArgs, case: BenchCase) -> None:
+    env = {
+        "VLLM_LOGGING_LEVEL": "ERROR",
+        "VLLM_MOE_DP_CHUNK_SIZE": str(max(bench.tokens_per_rank)),
+    }
+    vllm_config = _make_vllm_config(
+        world_size=bench.world_size,
+        backend=bench.backend,
+        enable_eplb=case.enable_eplb,
+    )
+    parallel_launch_with_config(
+        bench.world_size,
+        _run_case_worker,
+        vllm_config,
+        env,
+        bench,
+        case,
+    )
+
+
+def _read_jsonl(path: str) -> list[dict]:
+    if not os.path.exists(path):
+        return []
+    out = []
+    with open(path, encoding="utf-8") as f:
+        for line in f:
+            line = line.strip()
+            if not line:
+                continue
+            out.append(json.loads(line))
+    return out
+
+
+def _mean(xs: list[float]) -> float:
+    return sum(xs) / len(xs)
+
+
+def _std(xs: list[float]) -> float:
+    mu = _mean(xs)
+    return math.sqrt(sum((x - mu) ** 2 for x in xs) / len(xs))
+
+
+def _parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        description="Benchmark modular MoE kernel under EPLB on/off and token skew."
+    )
+    parser.add_argument("--world-size", type=int, default=2)
+    parser.add_argument(
+        "--backend",
+        type=str,
+        default="allgather_reducescatter",
+        help="MoE all2all backend. EPLB currently supports allgather_reducescatter.",
+    )
+    parser.add_argument(
+        "--routing-space",
+        choices=["physical_gpu", "logical_owner"],
+        default="physical_gpu",
+        help=(
+            "physical_gpu: directly control final physical-GPU token share for "
+            "one MoE layer; logical_owner: legacy logical-owner routing control."
+        ),
+    )
+    parser.add_argument("--num-experts", type=int, default=64)
+    parser.add_argument("--num-redundant-experts", type=int, default=64)
+    parser.add_argument("--topk", type=int, default=4)
+    parser.add_argument("-k", type=int, default=2048, help="hidden size")
+    parser.add_argument("-n", type=int, default=1024, help="intermediate size")
+    parser.add_argument(
+        "--tokens",
+        type=int,
+        default=4096,
+        help="tokens per rank when --tokens-per-rank is not set",
+    )
+    parser.add_argument(
+        "--tokens-per-rank",
+        type=str,
+        default=None,
+        help="comma separated token counts per rank, e.g. 8192,8192,4096,4096",
+    )
+    parser.add_argument(
+        "--dest-rank-matrix",
+        type=str,
+        default=None,
+        help=(
+            "source-rank -> destination-rank probabilities as rows separated by '/' "
+            "and columns by ','. Example for 4 GPUs: "
+            "0.85,0.10,0.03,0.02/0.10,0.80,0.05,0.05/"
+            "0.05,0.10,0.75,0.10/0.05,0.05,0.10,0.80"
+        ),
+    )
+    parser.add_argument(
+        "--physical-rank-probs",
+        type=str,
+        default=None,
+        help=(
+            "final physical-GPU token proportions, shared by all ranks, "
+            "comma separated. Example for 4 GPUs: 0.4,0.3,0.2,0.1"
+        ),
+    )
+    parser.add_argument(
+        "--total-tokens",
+        type=int,
+        default=None,
+        help=(
+            "total source tokens across all ranks for Monte Carlo mode. "
+            "If set and --tokens-per-rank is not set, tokens will be split "
+            "roughly evenly across ranks."
+        ),
+    )
+    parser.add_argument(
+        "--target-dest-cv",
+        type=float,
+        default=None,
+        help=(
+            "target coefficient of variation of destination GPU token "
+            "proportions. For N GPUs, cv = std / (1/N) = N * std."
+        ),
+    )
+    parser.add_argument(
+        "--target-dest-std",
+        type=float,
+        default=None,
+        help="target standard deviation of destination GPU token proportions",
+    )
+    parser.add_argument(
+        "--target-dest-entropy",
+        type=float,
+        default=None,
+        help=(
+            "target normalized entropy of destination GPU token proportions, "
+            "in [0, 1]"
+        ),
+    )
+    parser.add_argument(
+        "--num-random-trials",
+        type=int,
+        default=0,
+        help=(
+            "number of Monte Carlo trials. Each trial samples a destination GPU "
+            "distribution close to target std/entropy."
+        ),
+    )
+    parser.add_argument(
+        "--sample-attempts",
+        type=int,
+        default=2000,
+        help="candidate distributions to try per Monte Carlo trial",
+    )
+    parser.add_argument(
+        "--routing-pattern",
+        choices=["uniform", "rank0_hot", "rank_local_hot"],
+        default="rank_local_hot",
+    )
+    parser.add_argument("--hot-token-frac", type=float, default=0.95)
+    parser.add_argument("--hot-expert-frac", type=float, default=0.5)
+    parser.add_argument("--warmup-iters", type=int, default=20)
+    parser.add_argument("--iters", type=int, default=100)
+    parser.add_argument("--seed", type=int, default=7)
+    parser.add_argument("--mode", choices=["off", "on", "both"], default="both")
+    parser.add_argument("--output-json", type=str, default=None)
+    parser.add_argument(
+        "--append-output",
+        action="store_true",
+        help="append to --output-json instead of truncating before run",
+    )
+    parser.add_argument(
+        "--allow-non-modular",
+        action="store_true",
+        help="do not fail if FusedMoE modular kernel is not selected",
+    )
+    parser.add_argument("--verbose", action="store_true")
+    return parser.parse_args()
+
+
+def main() -> None:
+    args = _parse_args()
+
+    monte_carlo_mode = args.num_random_trials > 0
+    physical_mode = args.routing_space == "physical_gpu"
+    if monte_carlo_mode and args.dest_rank_matrix is not None:
+        raise ValueError(
+            "--dest-rank-matrix cannot be used together with --num-random-trials"
+        )
+    if physical_mode and args.dest_rank_matrix is not None:
+        raise ValueError("--dest-rank-matrix is only valid in --routing-space logical_owner")
+    if monte_carlo_mode and args.num_random_trials <= 0:
+        raise ValueError("--num-random-trials must be > 0 in Monte Carlo mode")
+    if monte_carlo_mode and args.sample_attempts <= 0:
+        raise ValueError("--sample-attempts must be > 0")
+    if (
+        monte_carlo_mode
+        and args.target_dest_cv is None
+        and args.target_dest_std is None
+        and args.target_dest_entropy is None
+    ):
+        raise ValueError(
+            "Monte Carlo mode requires --target-dest-cv and/or --target-dest-std and/or "
+            "--target-dest-entropy"
+        )
+    if args.tokens_per_rank is not None:
+        tokens_per_rank = _parse_int_list(args.tokens_per_rank)
+        if len(tokens_per_rank) != args.world_size:
+            raise ValueError(
+                f"--tokens-per-rank length ({len(tokens_per_rank)}) must match "
+                f"--world-size ({args.world_size})"
+            )
+    elif args.total_tokens is not None:
+        tokens_per_rank = _split_total_tokens(args.total_tokens, args.world_size)
+    else:
+        tokens_per_rank = [args.tokens for _ in range(args.world_size)]
+    if any(x <= 0 for x in tokens_per_rank):
+        raise ValueError("all token counts must be > 0")
+    dest_rank_matrix = None
+    if args.dest_rank_matrix is not None:
+        dest_rank_matrix = _parse_float_matrix(
+            args.dest_rank_matrix, args.world_size
+        )
+    physical_rank_probs = None
+    if args.physical_rank_probs is not None:
+        physical_rank_probs = _parse_float_probs(
+            args.physical_rank_probs, args.world_size
+        )
+    if args.total_tokens is not None and args.total_tokens <= 0:
+        raise ValueError("--total-tokens must be > 0")
+    if args.topk <= 0:
+        raise ValueError("--topk must be > 0")
+    if args.num_experts <= 0:
+        raise ValueError("--num-experts must be > 0")
+    if args.topk > args.num_experts:
+        raise ValueError("--topk must be <= --num-experts")
+    if not (0.0 <= args.hot_token_frac <= 1.0):
+        raise ValueError("--hot-token-frac must be in [0, 1]")
+    if not (0.0 < args.hot_expert_frac <= 1.0):
+        raise ValueError("--hot-expert-frac must be in (0, 1]")
+    if args.target_dest_entropy is not None and not (0.0 <= args.target_dest_entropy <= 1.0):
+        raise ValueError("--target-dest-entropy must be in [0, 1]")
+    if args.target_dest_cv is not None and args.target_dest_cv < 0.0:
+        raise ValueError("--target-dest-cv must be >= 0")
+    if args.target_dest_std is not None and args.target_dest_std < 0.0:
+        raise ValueError("--target-dest-std must be >= 0")
+    if args.iters <= 0 or args.warmup_iters < 0:
+        raise ValueError("--iters must be > 0 and --warmup-iters must be >= 0")
+    if physical_mode and args.mode != "off":
+        raise ValueError(
+            "--routing-space physical_gpu enforces final physical load directly, "
+            "so it only supports --mode off"
+        )
+    if physical_mode and args.target_dest_cv is None and args.target_dest_std is None \
+            and args.target_dest_entropy is None and physical_rank_probs is None:
+        raise ValueError(
+            "physical_gpu mode requires --physical-rank-probs or Monte Carlo "
+            "targets via --target-dest-cv/--target-dest-std/--target-dest-entropy"
+        )
+
+    if args.mode in {"off", "both"} and args.num_experts % args.world_size != 0:
+        raise ValueError(
+            f"eplb_off requires num_experts ({args.num_experts}) divisible by "
+            f"world_size ({args.world_size})"
+        )
+    if args.mode in {"on", "both"}:
+        num_physical = args.num_experts + args.num_redundant_experts
+        if num_physical % args.world_size != 0:
+            raise ValueError(
+                f"eplb_on requires num_physical_experts ({num_physical}) divisible "
+                f"by world_size ({args.world_size})"
+            )
+
+    if args.output_json is not None and (not args.append_output):
+        out_dir = os.path.dirname(args.output_json)
+        if out_dir:
+            os.makedirs(out_dir, exist_ok=True)
+        with open(args.output_json, "w", encoding="utf-8"):
+            pass
+
+    cases: list[BenchCase] = []
+    if args.mode in {"off", "both"}:
+        cases.append(BenchCase(name="eplb_off", enable_eplb=False))
+    if args.mode in {"on", "both"}:
+        cases.append(BenchCase(name="eplb_on", enable_eplb=True))
+
+    num_trials = args.num_random_trials if monte_carlo_mode else 1
+    for trial_id in range(num_trials):
+        trial_dest_rank_matrix = dest_rank_matrix
+        trial_physical_rank_probs = physical_rank_probs
+        if monte_carlo_mode:
+            target_dest_std = args.target_dest_std
+            if target_dest_std is None and args.target_dest_cv is not None:
+                target_dest_std = args.target_dest_cv / float(args.world_size)
+            sampled_probs = _sample_dest_probs_by_stats(
+                world_size=args.world_size,
+                target_std=target_dest_std,
+                target_entropy=args.target_dest_entropy,
+                sample_attempts=args.sample_attempts,
+                seed=args.seed + 1009 * (trial_id + 1),
+            )
+            if physical_mode:
+                trial_physical_rank_probs = sampled_probs
+                trial_dest_rank_matrix = None
+            else:
+                trial_dest_rank_matrix = [
+                    sampled_probs[:] for _ in range(args.world_size)
+                ]
+        else:
+            target_dest_std = args.target_dest_std
+            if target_dest_std is None and args.target_dest_cv is not None:
+                target_dest_std = args.target_dest_cv / float(args.world_size)
+
+        bench = BenchArgs(
+            world_size=args.world_size,
+            backend=args.backend,
+            routing_space=args.routing_space,
+            logical_num_experts=args.num_experts,
+            num_redundant_experts=args.num_redundant_experts,
+            topk=args.topk,
+            hidden_size=args.k,
+            intermediate_size=args.n,
+            tokens_per_rank=tokens_per_rank,
+            dest_rank_matrix=trial_dest_rank_matrix,
+            physical_rank_probs=trial_physical_rank_probs,
+            trial_id=(trial_id if monte_carlo_mode else None),
+            target_dest_cv=args.target_dest_cv,
+            target_dest_std=target_dest_std,
+            target_dest_entropy=args.target_dest_entropy,
+            routing_pattern=args.routing_pattern,
+            hot_token_frac=args.hot_token_frac,
+            hot_expert_frac=args.hot_expert_frac,
+            warmup_iters=args.warmup_iters,
+            iters=args.iters,
+            seed=args.seed + 7919 * trial_id,
+            require_modular=not args.allow_non_modular,
+            output_json=args.output_json,
+            verbose=args.verbose,
+        )
+
+        for case in cases:
+            _run_case(bench, case)
+
+    if args.output_json is not None:
+        rows = _read_jsonl(args.output_json)
+        case_rows: dict[str, list[dict]] = {}
+        for row in rows:
+            case = row.get("case")
+            if case not in {"eplb_off", "eplb_on"}:
+                continue
+            case_rows.setdefault(case, []).append(row)
+
+        aggregate_rows = []
+        for case_name, cur_rows in sorted(case_rows.items()):
+            if not cur_rows:
+                continue
+            tps = [float(r["global_tokens_per_s"]) for r in cur_rows]
+            lat = [float(r["max_rank_mean_step_ms"]) for r in cur_rows]
+            cvs = [
+                float(
+                    r["sampled_physical_cv"]
+                    if r.get("sampled_physical_cv") is not None
+                    else r["sampled_dest_cv"]
+                )
+                for r in cur_rows
+                if (
+                    r.get("sampled_physical_cv") is not None
+                    or r.get("sampled_dest_cv") is not None
+                )
+            ]
+            ents = [
+                float(
+                    r["sampled_physical_entropy"]
+                    if r.get("sampled_physical_entropy") is not None
+                    else r["sampled_dest_entropy"]
+                )
+                for r in cur_rows
+                if (
+                    r.get("sampled_physical_entropy") is not None
+                    or r.get("sampled_dest_entropy") is not None
+                )
+            ]
+            realized_cvs = [float(r["realized_physical_cv"]) for r in cur_rows]
+            realized_ents = [float(r["realized_physical_entropy"]) for r in cur_rows]
+            summary = {
+                "aggregate_case": case_name,
+                "benchmark_scope": "single_moe_layer_e2e",
+                "routing_space": cur_rows[0].get("routing_space"),
+                "num_trials": len(cur_rows),
+                "mean_tokens_per_s": _mean(tps),
+                "std_tokens_per_s": _std(tps),
+                "mean_max_rank_mean_step_ms": _mean(lat),
+                "std_max_rank_mean_step_ms": _std(lat),
+                "mean_sampled_dest_cv": (_mean(cvs) if cvs else None),
+                "std_sampled_dest_cv": (_std(cvs) if cvs else None),
+                "mean_sampled_dest_entropy": (_mean(ents) if ents else None),
+                "std_sampled_dest_entropy": (_std(ents) if ents else None),
+                "mean_realized_physical_cv": _mean(realized_cvs),
+                "std_realized_physical_cv": _std(realized_cvs),
+                "mean_realized_physical_entropy": _mean(realized_ents),
+                "std_realized_physical_entropy": _std(realized_ents),
+            }
+            aggregate_rows.append(summary)
+            print(json.dumps(summary, ensure_ascii=False))
+
+        if args.mode == "both":
+            trial_pairs: list[tuple[dict, dict]] = []
+            if monte_carlo_mode:
+                by_trial: dict[int, dict[str, dict]] = {}
+                for row in rows:
+                    if row.get("case") not in {"eplb_off", "eplb_on"}:
+                        continue
+                    trial_id = int(row.get("trial_id", -1))
+                    by_trial.setdefault(trial_id, {})[row["case"]] = row
+                for trial_id in sorted(by_trial):
+                    pair = by_trial[trial_id]
+                    if "eplb_off" in pair and "eplb_on" in pair:
+                        trial_pairs.append((pair["eplb_off"], pair["eplb_on"]))
+            else:
+                off_rows = [r for r in rows if r.get("case") == "eplb_off"]
+                on_rows = [r for r in rows if r.get("case") == "eplb_on"]
+                if off_rows and on_rows:
+                    trial_pairs.append((off_rows[-1], on_rows[-1]))
+
+            if trial_pairs:
+                speedups = []
+                off_tps = []
+                on_tps = []
+                off_lat = []
+                on_lat = []
+                for off, on in trial_pairs:
+                    off_tps.append(float(off["global_tokens_per_s"]))
+                    on_tps.append(float(on["global_tokens_per_s"]))
+                    off_lat.append(float(off["max_rank_mean_step_ms"]))
+                    on_lat.append(float(on["max_rank_mean_step_ms"]))
+                    speedups.append(
+                        float(on["global_tokens_per_s"])
+                        / max(float(off["global_tokens_per_s"]), 1e-12)
+                    )
+
+                summary = {
+                    "compare": (
+                        "eplb_on_vs_off_trials"
+                        if monte_carlo_mode
+                        else "eplb_on_vs_off"
+                    ),
+                    "benchmark_scope": "single_moe_layer_e2e",
+                    "num_trials": len(trial_pairs),
+                    "mean_off_tokens_per_s": _mean(off_tps),
+                    "mean_on_tokens_per_s": _mean(on_tps),
+                    "std_off_tokens_per_s": _std(off_tps),
+                    "std_on_tokens_per_s": _std(on_tps),
+                    "mean_speedup_x": _mean(speedups),
+                    "std_speedup_x": _std(speedups),
+                    "mean_off_max_rank_mean_step_ms": _mean(off_lat),
+                    "mean_on_max_rank_mean_step_ms": _mean(on_lat),
+                }
+                aggregate_rows.append(summary)
+                print(json.dumps(summary, ensure_ascii=False))
+
+        if aggregate_rows:
+            with open(args.output_json, "a", encoding="utf-8") as f:
+                for row in aggregate_rows:
+                    f.write(json.dumps(row, ensure_ascii=False) + "\n")
+
+
+if __name__ == "__main__":
+    main()
