-    """Uniform quantization of values to VQB bits, pack, and store with scale/zero."""
-    val_cache_offset = KPS
-
-    if VQB == 3:
-        val_vec = tl.load(Value_ptr + base + d_offs, mask=d_mask, other=0.0).to(
-            tl.float32
