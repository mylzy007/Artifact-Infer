-        sc_u16 = sc_f16.to(tl.uint16, bitcast=True)
-        tl.store(KV_cache_ptr + slot_base + sc_offset, (sc_u16 & 0xFF).to(tl.uint8))
-        tl.store(
-            KV_cache_ptr + slot_base + sc_offset + 1,
-            ((sc_u16 >> 8) & 0xFF).to(tl.uint8),
