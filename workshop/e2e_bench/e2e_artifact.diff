-        # ============================================================
-        # WEIGHTED VALUE ACCUMULATION
-        # ============================================================
-        acc = acc * re_scale + tl.sum(p[:, None] * values, 0)
-        l_prev = l_prev * re_scale + tl.sum(p, 0)
